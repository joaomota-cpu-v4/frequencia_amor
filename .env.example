# Use one token for every pixel it can access:
META_ACCESS_TOKEN=
META_PIXEL_IDS=457573061386079,280093672683803,3419148448260520

# Or use a different token per pixel (takes precedence over the variables above):
# META_CAPI_CONFIG={"457573061386079":"TOKEN_1","280093672683803":"TOKEN_2","3419148448260520":"TOKEN_3"}

# Optional Meta Events Manager test code. Remove it in production after validation.
META_TEST_EVENT_CODE=

# Optional override if your Meta account requires another supported Graph API version.
META_GRAPH_API_VERSION=v23.0
